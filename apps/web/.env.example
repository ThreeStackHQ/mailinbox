# Database
DATABASE_URL=postgresql://user:password@localhost:5432/mailinbox

# Auth (NextAuth v5) — Sprint 1.6
AUTH_SECRET=your-nextauth-secret-min-32-chars

# Stripe — Sprint 1.8
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...

# Cloudflare R2 (S3-compatible) — Sprint 1.4
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_BUCKET_NAME=mailinbox-emails
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# Cron Security
CRON_SECRET=your-cron-secret-min-32-chars
